{
  "name": "n8n-nodes-smartdocs",
  "version": "0.1.0",
  "description": "n8n community node for SmartDocs — automate document signing workflows.",
  "keywords": ["n8n-community-node-package", "n8n", "smartdocs", "esignature", "signing"],
  "license": "MIT",
  "homepage": "https://smartdocs.de",
  "author": { "name": "Ahmet Zambak" },
  "repository": { "type": "git", "url": "git+https://github.com/ahmetzambak/n8n-nodes-smartdocs.git" },
  "engines": { "node": ">=20" },
  "main": "index.js",
  "scripts": {
    "build": "npx rimraf dist && tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build && eslint nodes credentials package.json --config .eslintrc.prepublish.js",
    "test": "jest"
  },
  "files": ["dist"],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": ["dist/credentials/SmartDocsApi.credentials.js"],
    "nodes": [
      "dist/nodes/SmartDocs/SmartDocs.node.js",
      "dist/nodes/SmartDocs/SmartDocsTrigger.node.js"
    ]
  },
  "dependencies": { "form-data": "^4.0.0" },
  "peerDependencies": { "n8n-workflow": "*" },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.0",
    "gulp": "^5.0.0",
    "jest": "^29.7.0",
    "n8n-workflow": "*",
    "prettier": "^3.3.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.5.0"
  }
}
